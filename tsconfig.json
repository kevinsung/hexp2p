{
  "compilerOptions": {
    "target": "ES2018",
    // ESNext (rather than CommonJS) so that `import.meta.url`, used by the
    // computer-AI worker's webpack 5 `new Worker(new URL(...))` bundling
    // idiom, type-checks. This only affects `tsc --noEmit` type-checking;
    // actual module output is still produced by babel-loader/babel-jest per
    // their own config, unaffected by this setting.
    "module": "ESNext",
    "lib": ["dom", "esnext"],
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "jsx": "react",
    "strict": true,
    "pretty": true,
    "sourceMap": true,
    /* Additional Checks */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    /* Module Resolution Options */
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true
  },
  "exclude": ["test", "dist"]
}
