# Firebase project configuration (Project settings > General > Your apps > Web app).
# Copy this file to .env and fill in the values from your own Firebase project.
# These values are bundled into the client and are not secret - see README.md.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
